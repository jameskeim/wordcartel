# Maintainer: James Keim <email@jameskeim.com>
#
# Binary package for the optimized `release-dist` build of wordcartel (binary: wcartel).
#
# Why a binary package (not build-from-source): the crate has an out-of-repo path
# dependency (../../par-command/repar) that lives outside this git tree, so it cannot be
# built inside makepkg's sandboxed $srcdir. Instead, build the optimized binary once from
# the full workspace, then package it:
#
#   cargo build --profile release-dist -p wordcartel --bin wcartel
#   cd packaging/arch && makepkg -f
#
pkgname=wordcartel
pkgver=0.3.0
pkgrel=1
pkgdesc='Markdown-first terminal word processor (wcartel) — optimized release-dist build'
arch=('x86_64')
url='https://github.com/jameskeim/wordcartel'
license=('MIT')
depends=('glibc' 'gcc-libs')
optdepends=(
  'wayland: native Wayland clipboard (dlopened at runtime)'
  'libxcb: native X11 clipboard (dlopened at runtime)'
  'libx11: native X11 clipboard (dlopened at runtime)'
  'wl-clipboard: wl-copy external clipboard provider (fallback chain)'
  'xclip: xclip external clipboard provider (fallback chain)'
  'pandoc-cli: markdown export to html/docx/pdf (shells out to pandoc)'
  'texlive-xetex: PDF export via pandoc --pdf-engine=xelatex'
  'harper: grammar/spelling diagnostics in Review mode (harper-ls language server)'
)
provides=('wcartel')
# The release-dist profile already strips the binary; skip makepkg's strip/debug stages.
options=('!strip' '!debug')

# Absolute path to the workspace root (this PKGBUILD lives in packaging/arch/).
_root() { realpath "$startdir/../.."; }

pkgver() {
  # Tag-anchored (SemVer, tags `vX.Y.Z`): exactly on a tag → `0.1.0`; N commits past →
  # `0.1.0.rN.gHASH` (monotonic). Falls back to a commit-count snapshot if no tag is reachable.
  local root; root="$(_root)"
  cd "$root"
  git describe --tags 2>/dev/null | sed 's/^v//;s/-\([0-9]*\)-g/.r\1.g/' \
    || printf '0.0.0.r%s.g%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  local root; root="$(_root)"
  local bin="$root/target/release-dist/wcartel"
  if [[ ! -x "$bin" ]]; then
    error 'release-dist binary not found: %s' "$bin"
    plainerror 'Build it first: cargo build --profile release-dist -p wordcartel --bin wcartel'
    return 1
  fi
  install -Dm755 "$bin" "$pkgdir/usr/bin/wcartel"
  install -Dm644 "$root/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
